// AmBe source placed 20 cm in front of the detector
/control/verbose 1
/run/verbose 1
/event/verbose 0
/tracking/verbose 0

# GPS at 20 cm in front of bar along -z
/gps/pos/type Point
/gps/pos/centre 0 0 -22.7 cm
/gps/ang/type iso
/gps/particle neutron
/gps/ene/mono 4 MeV

/run/initialize
/run/beamOn 10000


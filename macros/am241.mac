# Am-241: alpha source — we simulate the gamma x-rays (approx 59.5 keV) if needed
/control/verbose 1
/run/verbose 1
/event/verbose 0
/tracking/verbose 0

# GPS at PMT window
/gps/pos/type Point
/gps/pos/centre 0 0 -2.7 cm
/gps/ang/type iso
/gps/particle gamma
/gps/ene/mono 59.5 keV

/run/initialize
/run/beamOn 10000


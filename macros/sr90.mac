# Sr-90/Y-90 beta source (approx Y-90 endpoint ~2.28 MeV, Sr-90 ~546 keV). Use 546 keV electron as proxy.
/control/verbose 1
/run/verbose 1
/event/verbose 0
/tracking/verbose 0

# GPS at PMT window
/gps/pos/type Point
/gps/pos/centre 0 0 -2.7 cm
/gps/ang/type iso
/gps/particle e-
/gps/ene/mono 546 keV

/run/initialize
/run/beamOn 10000


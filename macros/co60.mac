 # Co-60: two gammas at ~1173.2 keV and 1332.5 keV; use 1173.2 keV for a simple test
 /control/verbose 1
 /run/verbose 1
 /event/verbose 0
 /tracking/verbose 0
 
 # GPS at PMT window
 /gps/pos/type Point
 /gps/pos/centre 0 0 -2.7 cm
 /gps/ang/type iso
 /gps/particle gamma
 /gps/ene/mono 1173.2 keV
 
 /run/initialize
 /run/beamOn 10000

